# BOUBANE DASHBOARD - Configuration Production
# ============================================

# URL de l'application (utiliser le subdomain app.boubane.ai en prod)
APP_URL="https://app.boubane.ai"

# Vitrine Boubane (pour redirection login/auth)
SITE_URL="https://boubane.ai"

# Gemini API Key - AI Studio configure automatiquement
GEMINI_API_KEY="your_gemini_api_key"

# Secret webhook pour securiser les endpoints VPS -> Dashboard
API_WEBHOOK_SECRET="change_me_to_a_secure_token"

# ===========================================
# HERMES AGENT CONFIGURATION
# ===========================================
# Ces variables permettent a un agent Hermes externe de se connecter

# URL du dashboard (ou Hermes doit pointer)
HERMES_DASHBOARD_URL="https://app.boubane.ai"

# ID unique de l'agent Hermes
HERMES_AGENT_ID="hermes-1"

# Cle API optionnelle pour authentifier Hermes
HERMES_API_KEY=""

# Vercel Deployment (automatique)
# NODE_ENV=production

